              "questionInfo": "School-age child weight measurement in kilograms",
              "validators": []
            },
            {
              "label": "Height (cm)",
              "type": "obs",
              "required": false,
              "id": "schoolAgeHeight",
              "questionOptions": {
                "concept": "5090AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number",
                "step": "0.01"
              },
              "questionInfo": "School-age child height measurement in centimeters",
              "validators": []
            },
