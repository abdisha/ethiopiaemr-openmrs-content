            {
              "label": "WHO_Date & Time",
              "type": "obs",
              "questionOptions": {
                "rendering": "datetime",
                "concept": "MISSING_WHO_DATE_TIME"
              },
              "id": "dateTime"
            }
          ]
        },
        {
          "label": "Vital Signs",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Blood Pressure",
              "type": "obsGroup",
              "questionOptions": {
                "rendering": "group",
                "concept": "1114AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
              },
              "id": "bloodPressure",
              "questions": [
                {
                  "label": "Systolic",
                  "type": "obs",
                  "questionOptions": {
                    "rendering": "number",
                    "concept": "5085AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "min": "0",
                    "max": "300"
                  },
                  "id": "systolic",
                  "alert": {
                    "alertWhenExpression": "myValue && (myValue >= 140 || myValue < 90)",
                    "message": "Systolic BP is out of range (Normal range 90-139 mmHg)"
                  }
                },
                {
                  "label": "Diastolic", 
                  "type": "obs",
                  "questionOptions": {
                    "rendering": "number",
                    "concept": "5086AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "min": "0",
                    "max": "200"
                  },
                  "id": "diastolic",
                  "alert": {
                    "alertWhenExpression": "myValue && (myValue >= 90 || myValue < 60)",
                    "message": "Diastolic BP is out of range (Normal range 60-89 mmHg)"
                  }
                }
              ]
            },
            {
              "label": "Mean Arterial Pressure",
              "type": "obs",
              "questionOptions": {
                "rendering": "number",
                "concept": "MISSING_MEAN_ARTERIAL_PRESSURE",
                "min": "0",
                "max": "200"
              },
              "id": "meanArterialPressure"
            },
            {
              "label": "Pulse rate",
              "type": "obs",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "200"
              },
              "id": "pulseRate",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 100.5 || myValue < 59.5)",
                "message": "Pulse Rate is out of range (Normal range 60-100)"
              }
            },
            {
              "label": "Respiratory Rate",
              "type": "obs", 
              "questionOptions": {
                "rendering": "number",
                "concept": "5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "60"
              },
              "id": "respiratoryRate",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 25 || myValue < 12)",
                "message": "Respiratory Rate is out of range (Normal range 12-24 breaths/min)"
              }
            },
            {
              "label": "ER, Temperature",
              "type": "obs",
              "questionOptions": {
                "rendering": "number",
                "concept": "5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "25",
                "max": "43"
              },
              "id": "temperature",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 37.5 || myValue < 35)",
                "message": "Temperature is out of range (Normal range 35-37.5°C)"
              }
            },
            {
              "label": "Oxygen Saturation",
              "type": "obs",
              "questionOptions": {
                "rendering": "number", 
                "concept": "5092AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "100"
              },
              "id": "oxygenSaturation",
              "alert": {
                "alertWhenExpression": "myValue && myValue < 90",
                "message": "Oxygen Saturation is critically low (Normal range >90%)"
              }
            },
            {
              "label": "RBS",
              "type": "obs",
              "questionOptions": {
                "rendering": "number",
                "concept": "887AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "500"
              },
              "id": "rbs"
            }
          ]
