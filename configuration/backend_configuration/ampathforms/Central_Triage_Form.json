{
  "name": "Central Triage Form",
  "description": "Central Triage Form for vital signs assessment",
  "version": "1.0",
  "published": true,
  "uuid": "ff723d59-0650-4b84-858d-c1045b690683",
  "retired": false,
  "encounter": "Triage",
  "pages": [
    {
      "label": "Visit Details",
      "sections": [
        {
          "label": "Encounter Details",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Visit Date:",
              "type": "encounterDatetime",
              "required": "true",
              "id": "encDate",
              "readonly": false,
              "questionOptions": {
                "rendering": "date"
              },
              "validators": [
                {
                  "type": "date",
                  "allowFutureDates": "false"
                }
              ]
            },
            {
              "label": "Provider:",
              "type": "encounterProvider",
              "required": "true",
              "questionOptions": {
                "rendering": "ui-select-extended",
                "isSearchable": true
              },
              "id": "encProvider",
              "readonly": false
            },
            {
              "label": "Location:",
              "type": "encounterLocation",
              "required": "true",
              "questionOptions": {
                "rendering": "ui-select-extended",
                "datasource": {
                  "name": "location_datasource",
                  "config": {
                    "tag": "Login Location"
                  }
                }
              },
              "id": "encLocation",
              "readonly": false
            }
          ]
        }
      ]
    },
    {
      "label": "Central Triage Assessment",
      "sections": [
        {
          "label": "Vital Signs",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Pulse (60-100)",
              "type": "obs",
              "id": "pulse",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "questionInfo": "Normal range: 60-100 bpm",
              "alert": {
                "alertWhenExpression": "myValue && (myValue < 60 || myValue > 100)",
                "message": "Pulse is outside the normal range (60–100 bpm). Abnormal"
              }
            }
          ]
        },
        {
          "label": "Blood Pressure",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Systolic (90-120)",
              "type": "obs",
              "id": "systolicBP",
              "questionOptions": {
                "rendering": "number",
                "concept": "5085AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "questionInfo": "Normal range: 90-120 mmHg",
              "alert": {
                "alertWhenExpression": "myValue && (myValue < 90 || myValue > 120)",
                "message": "Systolic BP is outside the normal range (90–120 mmHg). Abnormal"
              }
            },
            {
              "label": "Diastolic (60-90)",
              "type": "obs",
              "id": "diastolicBP",
              "questionOptions": {
                "rendering": "number",
                "concept": "5086AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "questionInfo": "Normal range: 60-90 mmHg",
              "alert": {
                "alertWhenExpression": "myValue && (myValue < 60 || myValue > 90)",
                "message": "Diastolic BP is outside the normal range (60–90 mmHg). Abnormal"
              }
            },
            {
              "label": "Posture",
              "type": "obs",
              "id": "posture",
              "questionOptions": {
                "rendering": "radio",
                "concept": "159633AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "answers": [
                  {
                    "concept": "159630AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Sitting"
                  },
                  {
                    "concept": "159629AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Supine"
                  }
                ]
              }
            }
          ]
        },
        {
          "label": "Additional Vital Signs",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Temperature (36.5-37.5)",
              "type": "obs",
              "id": "temperature",
              "questionOptions": {
                "rendering": "number",
                "concept": "5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "25",
                "max": "43",
                "step": "0.01"
              },
              "questionInfo": "Normal range: 36.5-37.5°C",
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 37.5 || myValue < 35)",
                "message": "Temperature is out of range (Normal range 35-37.5°C)"
              }
            },
            {
              "label": "RR (16-24)",
              "type": "obs",
              "id": "respiratoryRate",
              "questionOptions": {
                "rendering": "number",
                "concept": "5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "questionInfo": "Normal range: 16-24 breaths/min",
              "alert": {
                "alertWhenExpression": "myValue && (myValue < 16 || myValue > 24)",
                "message": "Respiratory Rate is outside the normal range (16–24 breaths/min). Abnormal"
              }
            },
            {
              "label": "Saturation (SPO2%)",
              "type": "obs",
              "id": "spo2",
              "questionOptions": {
                "rendering": "number",
                "concept": "5092AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "100",
                "step": "0.01"
              },
              "questionInfo": "Normal: >90%",
              "alert": {
                "alertWhenExpression": "myValue && myValue <= 90",
                "message": "SPO2 is below the normal range (>90%). Abnormal"
              }
            },
            {
              "label": "Weight",
              "type": "obs",
              "id": "weight",
              "questionOptions": {
                "rendering": "number",
                "concept": "5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              }
            },
            {
              "label": "Height",
              "type": "obs",
              "id": "height",
              "questionOptions": {
                "rendering": "number",
                "concept": "5090AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              }
            },
            {
              "label": "BMI (Kg/m2)",
              "type": "obs",
              "id": "bmi",
              "questionOptions": {
                "rendering": "number",
                "concept": "1342AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "calculate": {
                  "calculateExpression": "calcBMI(height,weight)"
                },
                "step": "0.01"
              }
            }
          ]
        },
        {
          "label": "Disability",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Disability category",
              "type": "obs",
              "id": "disabilityStatus",
              "questionOptions": {
                "rendering": "radio",
                "concept": "a1ee71ae-0a4d-4944-83fe-d8e067e4f7a0",
                "answers": [
                  {
                    "concept": "7019aea1-fb85-4bcd-9c55-b2ca8d7bb282",
                    "label": "Vision loss"
                  },
                  {
                    "concept": "9adf601a-95f9-4598-8ec1-32463494f316",
                    "label": "Hearing loss"
                  },
                  {
                    "concept": "831a4037-2511-4c35-b483-2579aefb9675",
                    "label": "Mobility impairment"
                  },
                  {
                    "concept": "12fd5e41-59f8-4a55-8a36-3d3ceb401006",
                    "label": "No disability"
                  },
                  {
                    "concept": "94c5cf7f-68d9-49a9-afe0-8f5574bc5f78",
                    "label": "Others"
                  }
                ]
              }
            },
            {
              "label": "Specify other disability",
              "type": "obs",
              "id": "disabilityStatusOtherSpecify",
              "questionOptions": {
                "rendering": "text",
                "concept": "5be7e120-cca3-4f5d-a9a3-66626b498c94"
              },
              "hide": {
                "hideWhenExpression": "isEmpty(disabilityStatus) || disabilityStatus !== '94c5cf7f-68d9-49a9-afe0-8f5574bc5f78'"
              }
            }
          ]
        }
      ]
    }
  ],
  "processor": "EncounterFormProcessor",
  "referencedForms": []
}
