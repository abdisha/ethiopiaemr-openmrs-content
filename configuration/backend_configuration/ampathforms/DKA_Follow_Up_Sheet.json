              "required": false,
              "id": "height",
              "questionOptions": {
                "rendering": "number",
                "concept": "5090AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              }
            },
            {
              "label": "Pain Score",
              "type": "obs",
              "required": true,
              "id": "painScore",
              "questionOptions": {
                "rendering": "number",
                "concept": "160287AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "10",
                "step": "0.01"
              }
            }
          ]
        }
