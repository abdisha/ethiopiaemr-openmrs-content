        },
        {
          "label": "Vital Signs",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Pulse Rate",
              "type": "obs",
              "required": false,
              "id": "pulse",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "300",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 100.5 || myValue < 59.5)",
                "message": "Pulse Rate is out of range (Normal range 60-100)"
              },
              "questionInfo": "Normal range: 60-100 bpm"
            },
            {
              "label": "Systolic BP",
              "type": "obs",
              "required": false,
              "id": "systolic",
              "questionOptions": {
                "rendering": "number",
                "concept": "5085AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 130.5 || myValue < 119.5)",
                "message": "Systolic is out of range (Normal range 120-130)"
              },
              "questionInfo": "Normal range: 90-120 mmHg"
            },
            {
              "label": "Diastolic BP",
              "type": "obs",
              "required": false,
              "id": "diastolic",
              "questionOptions": {
                "rendering": "number",
                "concept": "5086AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 85.5 || myValue < 79.5)",
                "message": "Diastolic is out of range (Normal range 80-85)"
              },
              "questionInfo": "Normal range: 60-90 mmHg"
            },
            {
              "label": "Posture",
              "type": "obs",
              "required": false,
              "id": "posture",
              "questionOptions": {
                "rendering": "radio",
                "concept": "159633AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "answers": [
                  {
                    "concept": "159630AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Sitting"
                  },
                  {
                    "concept": "159629AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Supine"
                  }
                ]
              }
            },
            {
              "label": "Temperature (°C)",
              "type": "obs",
              "required": false,
              "id": "temperature",
              "questionOptions": {
                "rendering": "number",
                "concept": "5088AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "25",
                "max": "43",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 37.5 || myValue < 35)",
                "message": "Temperature is out of range (Normal range 35-37.5°C)"
              },
              "questionInfo": "Normal range: 36.5-37.5°C"
            },
            {
              "label": "Respiratory Rate",
              "type": "obs",
              "required": false,
              "id": "respiratoryRate",
              "questionOptions": {
                "rendering": "number",
                "concept": "5242AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && (myValue >= 25 || myValue < 12)",
                "message": "Respiratory Rate is out of range (Normal range 12-24)"
              },
              "questionInfo": "Normal range: 16-24 breaths/min"
            },
            {
              "label": "Saturation (SPO2%)",
              "type": "obs",
              "required": false,
              "id": "spo2",
              "questionOptions": {
                "rendering": "number",
                "concept": "5092AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "100",
                "step": "0.01"
              },
              "alert": {
                "alertWhenExpression": "myValue && myValue < 95",
                "message": "SPO2 is below normal (Normal range ≥95%)"
              },
              "questionInfo": "Normal range: ≥90%"
            },
            {
              "label": "Weight (kg)",
              "type": "obs",
              "required": false,
              "id": "weight",
              "questionOptions": {
                "rendering": "number",
                "concept": "5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              }
            },
            {
