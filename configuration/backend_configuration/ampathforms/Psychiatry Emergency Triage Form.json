        {
          "label": "SEVERITY OF ILLNESS CRITERIA",
          "isExpanded": "true",
          "questions": [
            {
              "label": "(Must meet one or more of 1, 2, or 3)",
              "type": "obs",
              "id": "severityOfIllnessCriteriaNote",
              "questionOptions": {
                "rendering": "text",
                "concept": "165095AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
              },
              "questionInfo": "Optional note or elaboration; criteria are captured in the structured sections below.",
              "readonly": false
            }
          ]
        },
        {
          "label": "1. Patient present as a danger to self as evidenced by one or more of the following:",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Danger to self criteria",
              "type": "obs",
              "id": "dangerToSelfCriteria",
              "questionOptions": {
                "rendering": "checkbox",
                "concept": "7d5b9c36-403d-4906-96d7-23628c9d12c9",
                "answers": [
                  {
                    "concept": "5764876b-af8f-439f-a5de-fab7f5272ad1",
                    "label": "A. Recent (within the past 72 hours) suicide attempt"
                  },
                  {
                    "concept": "65783b77-4045-4a8c-898e-c8815e2fc31a",
                    "label": "B. Documentation that the patient has a current suicide plan, specific suicide intent, or recurring suicidal ideation"
                  },
                  {
                    "concept": "dfc9afe8-b966-4e2e-8ece-a5dc1a1e8dd0",
                    "label": "C. Documentation of self-mutilate behavior (occurring within the past 72 hours)."
                  }
                ]
              },
              "readonly": false
            }
          ]
        },
        {
          "label": "2. Patient presents as a danger to others due to a DSM-V diagnosis as evidenced by one or more of the following:",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Danger to others criteria",
              "type": "obs",
              "id": "dangerToOthersCriteria",
              "questionOptions": {
                "rendering": "checkbox",
                "concept": "b641ce76-04c6-4564-88d4-48f8f1ef3eb8",
                "answers": [
                  {
                    "concept": "c4d10931-2f13-4256-a597-c042300234e1",
                    "label": "A. Dangerously aggressive behavior during the past seven days due to a DSM-V diagnosis"
                  },
                  {
                    "concept": "9b9dfd6c-f291-4e82-ae1a-3912079768e3",
                    "label": "B. Threats to kill or seriously injure another person with the means to carry out the threat AND the threatening behavior is due to a DSM-V diagnosis"
                  },
                  {
                    "concept": "2637473f-1323-4e02-9428-a7d02943d605",
                    "label": "C. Documentation that the patient has a current homicide plan, specific homicidal intent, or recurrent homicidal ideation AND this is due to a DSM-V diagnosis."
                  }
                ]
              },
              "readonly": false
            }
          ]
        },
        {
          "label": "3. Patient is gravely disabled and unable to care for self-due to a DSM-V diagnosis as evidenced by the following (a selection of indicator A must be accompanied by B OR C OR D):",
          "isExpanded": "true",
          "questions": [
            {
              "label": "Gravely disabled indicator A",
              "type": "obs",
              "id": "gravelyDisabledIndicatorA",
              "questionOptions": {
                "rendering": "radio",
                "concept": "ced3891a-d9c5-4a08-ba0c-8927e89a1253",
                "answers": [
                  {
                    "concept": "1065AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Selected"
                  },
                  {
                    "concept": "1066AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                    "label": "Not selected"
                  }
                ]
              },
              "readonly": false
            },
            {
              "label": "A. Documentation of a serious impairment in function (as compared to others of the same age) in one or more major life role (school, job, family, interpersonal relations, self-care, etc.) due to a DSM-V diagnosis AND (Indicator A must be accompanied by B OR C OR D)",
              "type": "obs",
              "id": "gravelyDisabledIndicatorADetails",
              "questionOptions": {
                "rendering": "textarea",
                "concept": "a289c15d-6f44-465f-b9d8-a362c6c67331",
                "rows": "4"
              },
              "readonly": false
            },
            {
              "label": "Gravely disabled indicator B",
              "type": "obs",
              "id": "gravelyDisabledIndicatorB",
              "questionOptions": {
                "rendering": "checkbox",
                "concept": "2ef55bac-d167-4386-b3d8-8d004ec1af57",
                "answers": [
                  {
                    "concept": "3fb46529-d635-4eaf-a960-40ce71e815eb",
                    "label": "1) Patient has a history of Refuse to psychotropic medications and patient refuses to use these medications as an outpatient"
                  },
                  {
                    "concept": "e17642af-63b9-45b1-b72d-c477a81f0dd1",
                    "label": "2) Patient is at risk of health or life due to non-compliance with medical regimens (e.g., insulin-dependent diabetes, etc.) and patient refuses these medical regimens as an outpatient."
                  },
                  {
                    "concept": "b7dcb9a7-fcf7-4eb1-bf9e-4642853b261d",
                    "label": "3) Patient with substance withdrawal symptoms not stay home more than two days"
                  },
                  {
                    "concept": "832a6c70-0f34-486e-b25b-433cb6442ce7",
                    "label": "4) Patient with severe drug side effects/ dystonia, NMS, Serotonin syndrome, toxicity/. OR"
