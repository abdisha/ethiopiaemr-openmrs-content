              "questionInfo": "Adult weight measurement in kilograms",
              "validators": []
            },
            {
              "label": "Height (cm)",
              "type": "obs",
              "required": false,
              "id": "aDultVitalHeight",
              "questionOptions": {
                "concept": "5090AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number",
                "min": "30",
                "max": "250",
                "step": "0.01"
