              "questionOptions": {
                "rendering": "number",
                "concept": "160287AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "max": "10",
                "step": "0.01"
              },
              "questionInfo": "Pain scale 0-10. 0=No pain, 10=Severe pain",
              "validators": [],
              "alert": {
                "alertWhenExpression": "myValue && myValue > 10",
                "message": "Pain score cannot exceed 10."
              }
            }
          ]
        }
      ]
