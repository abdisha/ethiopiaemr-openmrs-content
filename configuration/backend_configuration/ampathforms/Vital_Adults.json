              "label": "Weight (kg)",
              "type": "obs",
              "required": false,
              "id": "aDultVitalWeight",
              "questionOptions": {
                "concept": "5089AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "rendering": "number",
                "min": "1",
                "step": "0.01"
