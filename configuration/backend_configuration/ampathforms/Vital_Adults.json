              "id": "idPulse",
              "questionOptions": {
                "rendering": "number",
                "concept": "5087AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
                "min": "0",
                "step": "0.01"
              },
              "questionInfo": "Normal range for adults: 60-100 bpm",
