                  },
                  {
                    "label": "Supine",
                    "concept": "159629AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
                  }
                ]
              }
            }
          ]
        },
        {
          "label": "Vital",
          "isExpanded": "true",
          "questions": [
